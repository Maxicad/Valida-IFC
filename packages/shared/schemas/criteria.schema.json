{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Valida IFC Criterion",
  "type": "object",
  "required": ["code", "name", "severity", "rule_type", "active"],
  "properties": {
    "code": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "category": { "type": ["string", "null"] },
    "severity": { "enum": ["baixa", "moderada", "alta"] },
    "rule_type": { "type": "string", "minLength": 1 },
    "entity_ifc": { "type": ["string", "null"] },
    "property_name": { "type": ["string", "null"] },
    "operator": { "type": ["string", "null"] },
    "expected_value": {},
    "failure_message": { "type": ["string", "null"] },
    "fix_suggestion": { "type": ["string", "null"] },
    "reference": { "type": ["string", "null"] },
    "active": { "type": "boolean" },
    "natural_language_source": { "type": ["string", "null"] }
  }
}
