{
  "name": "valida-ifc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --filter @valida-ifc/web dev",
    "build": "pnpm --filter @valida-ifc/web build",
    "lint": "pnpm --filter @valida-ifc/web lint",
    "typecheck": "pnpm --filter @valida-ifc/web typecheck",
    "e2e": "docker compose -f docker-compose.e2e.yml --project-name valida-ifc-e2e down -v --remove-orphans && pnpm --filter @valida-ifc/web e2e"
  },
  "engines": {
    "node": ">=20"
  }
}
