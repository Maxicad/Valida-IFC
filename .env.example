APP_ENV=development

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://valida_ifc:valida_ifc@postgres:5432/valida_ifc
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_HOSTED_DOMAINS=[]
UPLOAD_MAX_BYTES=104857600
UPLOAD_MAX_FILES_PER_PROJECT=100
UPLOAD_MAX_FILES_PER_USER_PER_PROJECT=30
LOCAL_STORAGE_PATH=/data/storage
STORAGE_RETENTION_DAYS=90
AUDIT_QUEUE_NAME=ifc_audits
AUDIT_JOB_TIMEOUT_SECONDS=600
AUDIT_JOB_RESULT_TTL_SECONDS=3600
AUDIT_JOB_FAILURE_TTL_SECONDS=604800
AUDIT_JOB_MAX_RETRIES=2
AUDIT_JOB_RETRY_INTERVALS_SECONDS=[10,30]
WORKER_STARTUP_TIMEOUT_SECONDS=60
WORKER_STARTUP_POLL_SECONDS=1
ALERT_QUEUE_DEPTH_THRESHOLD=25
ALERT_API_5XX_THRESHOLD=1
ALERT_AUDIT_FAILURE_THRESHOLD=1
VIEWER_GEOMETRY_MAX_ELEMENTS=300
VIEWER_GEOMETRY_MAX_TRIANGLES_PER_ELEMENT=30000

# Worker
REDIS_URL=redis://redis:6379/0

# Database
POSTGRES_DB=valida_ifc
POSTGRES_USER=valida_ifc
POSTGRES_PASSWORD=valida_ifc
POSTGRES_PORT=5433
REDIS_PORT=6380
