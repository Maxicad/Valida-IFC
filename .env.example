APP_ENV=development

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://valida_ifc:valida_ifc@postgres:5432/valida_ifc
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
UPLOAD_MAX_BYTES=104857600
UPLOAD_MAX_FILES_PER_PROJECT=100
UPLOAD_MAX_FILES_PER_USER_PER_PROJECT=30
LOCAL_STORAGE_PATH=/data/storage
STORAGE_RETENTION_DAYS=90
AUDIT_QUEUE_NAME=ifc_audits
VIEWER_GEOMETRY_MAX_ELEMENTS=300
VIEWER_GEOMETRY_MAX_TRIANGLES_PER_ELEMENT=30000

# Worker
REDIS_URL=redis://redis:6379/0

# Database
POSTGRES_DB=valida_ifc
POSTGRES_USER=valida_ifc
POSTGRES_PASSWORD=valida_ifc
POSTGRES_PORT=5433
REDIS_PORT=6380
